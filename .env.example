# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
# Optional comma-separated extra frontend URLs, useful for Vercel preview deployments.
CLIENT_URLS=

# Database
# Local development:
MONGO_URI=mongodb://127.0.0.1:27017/drug_safety_checker
# Production example:
# MONGO_URI=your_managed_mongodb_connection_string

# External APIs
OPENFDA_EVENT_URL=https://api.fda.gov/drug/event.json
AI_SERVICE_URL=http://localhost:8000

# Optional OpenAI enrichment
# Leave empty to use local fallback rules only.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Client
VITE_API_URL=http://localhost:5000/api
